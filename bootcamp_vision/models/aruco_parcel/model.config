<?xml version="1.0"?>
<model>
  <name>aruco_parcel</name>
  <version>1.0</version>
  <sdf version="1.10">model.sdf</sdf>
  <author><name>Bootcamp ROS 2</name></author>
  <description>Colis carton (6 cm) avec marqueur ArUco DICT_4X4_50 sur le dessus
    (TP02). Taille du marqueur imprime : 0.05 m de cote (cf. README, pour solvePnP).
    Texture par defaut aruco_0.png ; spawn_object.py substitue selon aruco_id.</description>
</model>
